{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TOTP Generator",
  "version": "1.0.4",
  "identifier": "com.mkants.totp-generator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TOTP Generator",
        "width": 800,
        "height": 600,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/128x128.png"]
  }
}
